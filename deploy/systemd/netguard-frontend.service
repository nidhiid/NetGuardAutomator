[Unit]
Description=NetGuardAutomator React dashboard
After=network-online.target netguard-api.service
Wants=network-online.target
Requires=netguard-api.service

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/NetGuardAutomator/frontend
ExecStart=/usr/bin/npm run dev -- --host 0.0.0.0
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
